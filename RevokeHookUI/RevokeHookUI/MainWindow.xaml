<ui:FluentWindow
    x:Class="RevokeHookUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="RevokeHook 配置工具"
    Width="1040"
    Height="820"
    MinWidth="980"
    MinHeight="760"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="" CloseWindowByDoubleClickOnIcon="True"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="RevokeHook 配置工具"
                           FontSize="26"
                           FontWeight="Bold"/>
                <TextBlock x:Name="VersionHintTextBlock"
                           Margin="0,4,0,0"
                           Opacity="0.75"
                           Text="启动时会从本地 ini 和 Config3.json 读取配置。"/>
            </StackPanel>

            <WrapPanel Grid.Column="1"
                       VerticalAlignment="Center"
                       ItemHeight="36"
                       Orientation="Horizontal">
                <Button x:Name="LoadCloudButton"
                        Width="96"
                        Height="36"
                        Margin="0,0,8,0"
                        Content="云端配置"
                        Click="LoadCloudButton_Click"/>
                <Button x:Name="SaveIniButton"
                        Width="96"
                        Height="36"
                        Margin="0,0,8,0"
                        Content="保存配置"
                        Click="SaveIniButton_Click"/>
                <Button x:Name="SearchAllButton"
                        Width="96"
                        Height="36"
                        Margin="0,0,8,0"
                        Content="开始搜索"
                        Click="SearchAllButton_Click"/>
                <Button x:Name="CreateLinkButton"
                        Width="140"
                        Height="36"
                        Margin="0,0,8,0"
                        Content="创建桌面快捷方式"
                        Click="CreateLinkButton_Click"/>
                <Button x:Name="CheckUpdateButton"
                        Width="96"
                        Height="36"
                        Margin="0,0,8,0"
                        Content="检查更新"
                        Click="CheckUpdateButton_Click"/>
                <Button x:Name="ClearLogButton"
                        Width="96"
                        Height="36"
                        Content="清空日志"
                        Click="ClearLogButton_Click"/>
            </WrapPanel>
        </Grid>

        <ui:Card Grid.Row="4" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="字符串特征与搜索结果"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="特征码1"/>
                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             x:Name="Signature1TextBox"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="特征码2"/>
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             x:Name="Signature2TextBox"/>

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="特征码3"/>
                    <TextBox Grid.Row="4"
                             Grid.Column="1"
                             x:Name="Signature3TextBox"/>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="DeleteMessages 偏移"/>
                        <TextBox Grid.Column="1"
                                 x:Name="KeyFuncDelMsgOffsetTextBox"
                                 IsReadOnly="True"/>
                    </Grid>

                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="195"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="CoAddMessageToDB 偏移"/>
                        <TextBox Grid.Column="1"
                                 x:Name="KeyFuncAdd2DBOffsetTextBox"
                                 IsReadOnly="True"/>
                    </Grid>
                </Grid>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="96"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0"
                             Grid.Column="0"
                             x:Name="DeleteMessagesChainTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="13"/>
                    <TextBox Grid.Row="0"
                             Grid.Column="2"
                             x:Name="AddMessageToDbChainTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="13"/>

                    <Grid Grid.Row="2"
                          Grid.ColumnSpan="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <ProgressBar Grid.Column="0"
                                     x:Name="SearchProgressBar"
                                     Height="12"
                                     Minimum="0"
                                     Maximum="100"/>
                        <TextBlock Grid.Column="2"
                                   x:Name="SearchProgressTextBlock"
                                   VerticalAlignment="Center"
                                   Opacity="0.75"
                                   Text="等待搜索"/>
                    </Grid>
                </Grid>
            </Grid>
        </ui:Card>

        <ui:Card Grid.Row="6" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="[Setting]"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <UniformGrid Grid.Row="2"
                             Columns="4">
                    <CheckBox x:Name="AutoRunCheckBox"
                              Content="RevokeInject开机自启"/>
                    <CheckBox x:Name="OutputDebugMsgCheckBox"
                              Content="调试信息开关"/>
                    <CheckBox x:Name="OverTipCheckBox"
                              Content="注入完毕显示提醒"/>
                    <CheckBox x:Name="AntiRevokeSelfCheckBox"
                              Content="防撤回自己的消息"/>
                </UniformGrid>
            </Grid>
        </ui:Card>

        <ui:Card Grid.Row="8" Padding="16" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="信息输出"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Opacity="0.65"
                               Text="运行日志 / 搜索结果 / 错误信息"/>
                </Grid>

                <TextBox Grid.Row="2"
                         x:Name="LogTextBox"
                         VerticalAlignment="Stretch"
                         HorizontalAlignment="Stretch"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="13"/>
            </Grid>
        </ui:Card>
    </Grid>
</ui:FluentWindow>
