<ui:FluentWindow
    x:Class="RevokeHookUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="RevokeHook 配置工具"
    Width="1000"
    Height="820"
    MinWidth="1040"
    MinHeight="760"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <ui:TitleBar Grid.Row="0" Title="" CloseWindowByDoubleClickOnIcon="True">
        </ui:TitleBar>


        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="RevokeHook 配置工具"
                           FontSize="26"
                           FontWeight="Bold"/>
                <TextBlock x:Name="VersionHintTextBlock"
                           Margin="0,4,0,0"
                           Opacity="0.75"
                           Text="启动时会从本地 ini 和 Config2.json 读取配置。"/>
            </StackPanel>

            <WrapPanel Grid.Column="1"
                       VerticalAlignment="Center"
                       ItemHeight="36"
                       Orientation="Horizontal">
                <Button x:Name="LoadCloudButton"
                        Width="96"
                        Height="36"
                        Margin="0,0,8,0"
                        Content="云端配置"
                        Click="LoadCloudButton_Click"/>
                <Button x:Name="SaveIniButton"
                        Width="96"
                        Height="36"
                        Margin="0,0,8,0"
                        Content="保存配置"
                        Click="SaveIniButton_Click"/>
                <Button x:Name="SearchAllButton"
                        Width="96"
                        Height="36"
                        Margin="0,0,8,0"
                        Content="搜索全部"
                        Click="SearchAllButton_Click"/>
                <Button x:Name="CreateLinkButton"
                        Width="140"
                        Height="36"
                        Margin="0,0,8,0"
                        Content="创建桌面快捷方式"
                        Click="CreateLinkButton_Click"/>
                <Button x:Name="CheckUpdateButton"
                        Width="96"
                        Height="36"
                        Margin="0,0,8,0"
                        Content="检查更新"
                        Click="CheckUpdateButton_Click"/>
                <Button x:Name="ClearLogButton"
                        Width="96"
                        Height="36"
                        Content="清空日志"
                        Click="ClearLogButton_Click"/>
            </WrapPanel>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ui:Card Grid.Column="0" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="DelMsg 特征码搜索"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="96"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="特征码"/>
                        <TextBox Grid.Column="1"
                                 x:Name="DelMsgPatternTextBox"/>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="搜索结果偏移"/>
                            <TextBox Grid.Row="2"
                                     x:Name="DelMsgResultDeltaTextBox"/>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="结果预览"/>
                            <TextBox Grid.Row="2"
                                     x:Name="DelMsgSearchResultTextBox"
                                     IsReadOnly="True"/>
                        </Grid>

                        <Button Grid.Column="4"
                                Width="110"
                                Height="36"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Content="搜索特征码1"
                                Click="SearchDelMsgButton_Click"/>
                    </Grid>
                </Grid>
            </ui:Card>

            <ui:Card Grid.Column="2" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Add2DB 特征码搜索"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="96"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="特征码"/>
                        <TextBox Grid.Column="1"
                                 x:Name="Add2DBPatternTextBox"/>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="搜索结果偏移"/>
                            <TextBox Grid.Row="2"
                                     x:Name="Add2DBResultDeltaTextBox"/>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="结果预览"/>
                            <TextBox Grid.Row="2"
                                     x:Name="Add2DBSearchResultTextBox"
                                     IsReadOnly="True"/>
                        </Grid>

                        <Button Grid.Column="4"
                                Width="120"
                                Height="36"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Content="搜索特征码2"
                                Click="SearchAdd2DBButton_Click"/>
                    </Grid>
                </Grid>
            </ui:Card>
        </Grid>

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ui:Card Grid.Row="0" Grid.Column="0" Padding="16" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="[关键函数偏移]"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Text="DelMsg偏移"/>

                            <TextBox Grid.Column="1"
                                     x:Name="KeyFuncDelMsgOffsetTextBox"
                                     MinWidth="80"/>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Text="Add2DB偏移"/>

                            <TextBox Grid.Column="1"
                                     x:Name="KeyFuncAdd2DBOffsetTextBox"
                                     MinWidth="80"/>
                        </Grid>
                    </Grid>
                </Grid>
            </ui:Card>

            <ui:Card Grid.Row="0" Grid.Column="2" Padding="16" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="[DelMsg函数参数]"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Text="Msg参数index"/>

                            <TextBox Grid.Column="1"
                                     x:Name="DelMsgArgMsgIndexTextBox"
                                     MinWidth="60"/>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Text="RevokeXML偏移"/>

                            <TextBox Grid.Column="1"
                                     x:Name="DelMsgOffsetRevokeXmlTextBox"
                                     MinWidth="60"/>
                        </Grid>
                    </Grid>
                </Grid>
            </ui:Card>

            <ui:Card Grid.Row="2" Grid.Column="0" Padding="16" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="[Add2DB函数参数]"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Text="Msg参数index"/>

                            <TextBox Grid.Column="1"
                                     x:Name="Add2DBArgMsgIndexTextBox"
                                     MinWidth="60"/>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Text="Bool参数index"/>

                            <TextBox Grid.Column="1"
                                     x:Name="Add2DBArgBoolIndexTextBox"
                                     MinWidth="60"/>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Text="RevokeXML偏移"/>

                            <TextBox Grid.Column="1"
                                     x:Name="Add2DBOffsetRevokeXmlTextBox"
                                     MinWidth="60"/>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Text="SrvID偏移"/>

                            <TextBox Grid.Column="1"
                                     x:Name="Add2DBOffsetSrvIdTextBox"
                                     MinWidth="60"/>
                        </Grid>
                    </Grid>
                </Grid>
            </ui:Card>

            <ui:Card Grid.Row="2" Grid.Column="2" Padding="16" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="[Setting]"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <CheckBox Grid.Row="0"
                                  Grid.Column="0"
                                  x:Name="AutoRunCheckBox"
                                  Content="RevokeInject开机自启"/>

                        <CheckBox Grid.Row="0"
                                  Grid.Column="2"
                                  x:Name="OutputDebugMsgCheckBox"
                                  Content="调试信息开关"/>

                        <CheckBox Grid.Row="2"
                                  Grid.Column="0"
                                  x:Name="OverTipCheckBox"
                                  Content="注入完毕显示提醒"/>

                        <CheckBox Grid.Row="2"
                                  Grid.Column="2"
                                  x:Name="AntiRevokeSelfCheckBox"
                                  Content="防撤回自己的消息"/>
                    </Grid>
                </Grid>
            </ui:Card>
        </Grid>

        <ui:Card Grid.Row="8" Padding="16" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="信息输出"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Opacity="0.65"
                               Text="运行日志 / 搜索结果 / 错误信息"/>
                </Grid>

                <TextBox Grid.Row="2"
                         x:Name="LogTextBox"
                         VerticalAlignment="Stretch"
                         HorizontalAlignment="Stretch"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="13"/>
            </Grid>
        </ui:Card>
    </Grid>
</ui:FluentWindow>
